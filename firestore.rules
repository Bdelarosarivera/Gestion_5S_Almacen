rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // PHASE 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "bartolodelarosarivera@gmail.com";
    }

    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // PHASE 4: Validation Helpers
    function isValidAudit(data) {
      return data.id is string && data.id.size() > 0 &&
             data.area is string && data.area.size() > 0 &&
             data.auditor is string && data.auditor.size() > 0 &&
             data.date is string &&
             data.score is number &&
             data.answers is list &&
             data.userId is string; // Permitimos que cualquier ID de usuario sea el responsable
    }

    function isValidAction(data) {
      return data.id is string && data.id.size() > 0 &&
             data.auditId is string && data.auditId.size() > 0 &&
             data.area is string && data.area.size() > 0 &&
             data.questionId is number &&
             data.suggestedAction is string && data.suggestedAction.size() <= 1000 &&
             data.status in ['PENDING', 'IN_PROGRESS', 'CLOSED'] &&
             data.userId is string;
    }

    function isValidConfig(data) {
      return data.areas is list &&
             data.responsables is list &&
             data.questions is list &&
             data.userId is string;
    }

    // Collection Rules
    match /audits/{auditId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(auditId) && isValidAudit(incoming());
      allow update: if isSignedIn() && isValidAudit(incoming()); // Cualquier auditor puede actualizar
      allow delete: if isSignedIn(); // Cualquier auditor puede eliminar (incluyendo el "borrar todo" del owner)
    }

    match /actions/{actionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(actionId) && isValidAction(incoming());
      allow update: if isSignedIn() && isValidAction(incoming());
      allow delete: if isSignedIn();
    }

    match /config/{configId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(configId) && isValidConfig(incoming());
      allow update: if isSignedIn() && isValidConfig(incoming());
      allow delete: if isSuperAdmin(); // Solo el super admin puede borrar la config
    }
  }
}
